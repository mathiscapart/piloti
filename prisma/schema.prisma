// Piloti — schéma Prisma
// SQLite en dev ET prod (cette version). Pour scale national SGDF : passer "postgresql".
// Convention : enums portés comme `String` (SQLite ne supporte pas les enums Prisma).
// Les valeurs autorisées vivent dans `src/lib/enums.ts` (TS) — source unique côté app.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7 : l'URL vit dans prisma.config.ts (datasource.url),
// pas dans ce bloc. Le client runtime reçoit l'adapter better-sqlite3 (cf. src/lib/db.ts).
datasource db {
  provider = "sqlite"
}

// ----------------------------------------------------------------------------
// Better-auth (sessions / credentials / OAuth ready)
// ----------------------------------------------------------------------------

model User {
  // Better-auth required
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Piloti additional fields (exposed via better-auth `additionalFields`)
  firstName      String
  lastName       String
  role           String  @default("CHEF") // Role principal: ADMIN | CHEF | PARENT | SCOUT
  // US-29 — rôles fonctionnels additionnels (JSON: Role[]) cumulables avec le
  // rôle principal (ex. RESPONSABLE_GROUPE, TRESORIER, SECRETAIRE, MEMBRE_LOCAL).
  roles          String  @default("[]")
  status         String  @default("PENDING") // AccountStatus: PENDING | ACTIVE | REJECTED | SUSPENDED
  unit           String? // Unit: BLEUS | VERTS | ROUGES | PIOS | COMPAS
  phone          String?
  rejectedReason String?
  // US-26 — profil demandé à l'inscription (ex. "PARENT") : simple indication
  // pour aider l'admin à attribuer le bon rôle à la validation. Non privilégié.
  requestedRole  String?
  // US-P02 — jeton secret pour l'abonnement iCal (URL sans cookie). Généré à la
  // demande depuis « Mon compte ».
  calendarToken  String? @unique

  // US-26 — profil parent enrichi (annuaire des compétences pour aider le
  // groupe). Champs facultatifs ; `skillsConsent` = consentement RGPD pour
  // l'usage de ces données. Consultation réservée aux Responsables de Groupe.
  profession     String?
  skills         String? // savoir-faire utiles (texte libre / liste)
  availability   String? // disponibilités / envie d'aider
  helpNotes      String? // informations complémentaires
  skillsConsent  Boolean @default(false)

  // Better-auth relations
  sessions Session[]
  accounts Account[]

  // Piloti relations
  messages          Message[]         @relation("MessageAuthor")
  reactions         MessageReaction[] @relation("ReactionUser")
  channelReads      ChannelRead[]     @relation("ChannelReadUser")
  channelMutes      ChannelMute[]     @relation("ChannelMuteUser")
  polls             Poll[]            @relation("PollAuthor")
  pollVotes         PollVote[]        @relation("PollVoteUser")
  notifications     Notification[]    @relation("UserNotification")
  pushSubscriptions PushSubscription[]
  notificationPref  NotificationPreference?
  announcements     Announcement[]    @relation("AnnouncementAuthor")
  announcementReads AnnouncementRead[] @relation("AnnouncementReadUser")
  conversationsA    Conversation[]    @relation("ConversationUserA")
  conversationsB    Conversation[]    @relation("ConversationUserB")
  sentDirectMessages DirectMessage[]  @relation("DirectMessageSender")
  borrowedLoans     Loan[]     @relation("LoanBorrower")
  validatedReturns  Loan[]     @relation("LoanReturnedBy")
  dryingLoans       Loan[]     @relation("LoanDryingContact")
  reportedIncidents Incident[] @relation("IncidentReporter")
  resolvedIncidents Incident[] @relation("IncidentResolver")
  eventRegistrations EventRegistration[] @relation("UserEventRegistration")
  eventReminders    EventReminder[]    @relation("UserEventReminder")
  attendances       Attendance[]       @relation("UserAttendance")
  assignedTasks     Task[]             @relation("TaskAssignee")
  taskSignups       TaskSignup[]       @relation("TaskSignupUser")
  expensesDeclared  Expense[]          @relation("ExpenseDeclarant")
  expensesReviewed  Expense[]          @relation("ExpenseReviewer")
  campaignPayments  CampaignPayment[]  @relation("CampaignPaymentUser")
  // US — rattachement familial : liens parent↔jeune (un compte peut être parent
  // de plusieurs jeunes et un jeune avoir plusieurs responsables).
  familyAsParent    FamilyLink[]       @relation("FamilyParent")
  familyAsChild     FamilyLink[]       @relation("FamilyChild")
  // US-F — tranche de quotient familial (tarification solidaire SGDF).
  socialBracketId   String?
  socialBracket     SocialBracket?     @relation("UserSocialBracket", fields: [socialBracketId], references: [id], onDelete: SetNull)
  auditLogs         AuditLog[]

  @@index([status])
  @@index([role])
  @@index([socialBracketId])
}

// US-F — tranche de quotient familial (tarification solidaire SGDF).
// Définies une fois pour le groupe (T1…T5). Chaque famille est rangée dans une
// tranche stable, appliquée automatiquement aux événements ET aux cotisations.
// coefficientPermille = multiplicateur en pour-mille (1000 = ×1.0, 600 = ×0.6).
model SocialBracket {
  id                 String   @id @default(cuid())
  name               String
  coefficientPermille Int     @default(1000)
  order              Int      @default(0)
  archived           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  members User[] @relation("UserSocialBracket")

  @@index([archived])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ----------------------------------------------------------------------------
// Piloti — Catégories de matériel (gérées depuis l'admin)
// ----------------------------------------------------------------------------

model Category {
  slug      String   @id
  label     String
  // US-17 — comportements configurables hérités par tous les articles de la
  // catégorie. `canDry` = séchage possible (US-10) ; `requireWeighing` = pesée
  // obligatoire au retour (US-18).
  canDry          Boolean @default(false)
  requireWeighing Boolean @default(false)
  order     Int      @default(0)
  archived  Boolean  @default(false) // US-31 — catégorie archivée (masquée des listes de choix)
  createdAt DateTime @default(now())

  // US-24 — sous-catégories : auto-relation à 1 niveau (un parent → N enfants).
  // `onDelete: Restrict` empêche de supprimer un parent qui a encore des enfants.
  parentSlug String?
  parent     Category?  @relation("CategoryTree", fields: [parentSlug], references: [slug], onDelete: Restrict, onUpdate: Cascade)
  children   Category[] @relation("CategoryTree")

  @@index([parentSlug])
}

// ----------------------------------------------------------------------------
// Piloti — Inventaire & vie du matériel
// ----------------------------------------------------------------------------

model Equipment {
  id        String   @id @default(cuid())
  name      String
  category  String // EquipmentCategory: TENTE | MALLE | CUISINE | BIVOUAC | JEU | AUTRE
  totalQty  Int      @default(1)
  condition String   @default("BON") // EquipmentCondition: NEUF | BON | USE | A_REPARER | HORS_SERVICE
  location  String?
  photo     String?
  notes     String?
  archived  Boolean  @default(false)
  nfcUid    String?  @unique // US-15 — UID du tag NFC associé (scan → fiche article)
  baseWeightKg Float? // US-17/US-18 — poids de référence (catégorie pesable, 1 exemplaire)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans     Loan[]
  incidents Incident[]
  auditLogs AuditLog[]

  @@index([category])
  @@index([archived])
}

model Loan {
  id             String    @id @default(cuid())
  // US-32 — prêt groupé : les lignes (une par article) d'un même emprunt
  // partagent un `groupId`. Null = ancien prêt mono-article (legacy).
  groupId        String?
  equipmentId    String
  borrowerId     String
  quantity       Int       @default(1)
  startDate      DateTime
  expectedReturn DateTime
  returnedAt     DateTime?
  returnedById   String?
  status         String    @default("ACTIF") // LoanStatus: ACTIF | RETARD | RETOURNE | SECHAGE
  eventName      String? // libellé libre (legacy / si pas d'événement lié)
  // US-P12 — lien optionnel vers un événement du planning. Null = prêt non
  // rattaché. Les lignes d'un même prêt groupé partagent le même eventId.
  eventId        String?

  // Séchage (statut SECHAGE)
  dryingLocation   String?
  // US-23 — contact de séchage rattaché à un compte (référence User).
  // `dryingPersonName` est conservé comme snapshot/affichage et pour le legacy.
  dryingContactId  String?
  dryingPersonName String?

  // US-17/US-18 — poids relevé au retour (kg) si la catégorie l'exige.
  returnWeightKg Float?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipment  Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  borrower     User     @relation("LoanBorrower", fields: [borrowerId], references: [id])
  returnedBy   User?    @relation("LoanReturnedBy", fields: [returnedById], references: [id])
  dryingContact User?   @relation("LoanDryingContact", fields: [dryingContactId], references: [id])
  event        Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  auditLogs  AuditLog[]

  @@index([status])
  @@index([equipmentId])
  @@index([borrowerId])
  @@index([eventId])
  @@index([expectedReturn])
  @@index([groupId])
}

model Incident {
  id           String    @id @default(cuid())
  equipmentId  String
  reporterId   String
  types        String // JSON: IncidentType[] (cf. src/lib/incident-categories.ts)
  severity     String // IncidentSeverity: BLOQUANT | GENANT | MINEUR
  photos       String    @default("[]") // JSON: string[] (chemins relatifs)
  notes        String?
  resolvedAt   DateTime?
  resolvedById String?
  resolvedNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  equipment  Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  reporter   User       @relation("IncidentReporter", fields: [reporterId], references: [id])
  resolvedBy User?      @relation("IncidentResolver", fields: [resolvedById], references: [id])
  auditLogs  AuditLog[]

  @@index([severity])
  @@index([equipmentId])
  @@index([resolvedAt])
}

// ----------------------------------------------------------------------------
// Piloti — Dons de matériel (US-25). File d'attente : un don proposé n'entre
// dans le stock qu'après validation admin.
// ----------------------------------------------------------------------------

model Donation {
  id          String    @id @default(cuid())
  category    String // slug de catégorie (choisi dans la liste existante)
  name        String
  quantity    Int       @default(1)
  condition   String    @default("BON") // EquipmentCondition
  dropoffDate DateTime? // date de dépôt prévue
  donorName   String? // nom libre du donateur
  donorId     String? // user ayant soumis (si connecté)
  note        String?
  status      String    @default("PENDING") // DonationStatus: PENDING | APPROVED | REJECTED
  reviewedById String?
  reviewedAt  DateTime?
  rejectedReason String?
  createdEquipmentId String? // article créé lors de la validation
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// Piloti — Audit (toute mutation laisse une trace, cf. lib/audit.ts)
// ----------------------------------------------------------------------------

model AuditLog {
  id          String   @id @default(cuid())
  action      String // ex: EQUIPMENT_CREATED, LOAN_RETURNED, INCIDENT_REPORTED
  userId      String
  equipmentId String?
  loanId      String?
  incidentId  String?
  metadata    String   @default("{}") // JSON
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  equipment Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  loan      Loan?      @relation(fields: [loanId], references: [id], onDelete: SetNull)
  incident  Incident?  @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// Piloti — Événements (squelette V2, structure prête)
// ----------------------------------------------------------------------------

model Event {
  id          String   @id @default(cuid())
  name        String
  type        String // EventType: REUNION | WEEK_END | CAMP | SERVICE
  startDate   DateTime
  endDate     DateTime
  unit        String? // Unit — null = tout le groupe
  location    String?
  description String?
  createdById String? // auteur (chef) — null si compte supprimé
  // US-P04 — inscriptions : ouverture + date limite (déclenche les relances P06).
  registrationOpen     Boolean   @default(false)
  registrationDeadline DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // US-F05 — tarif demandé par jeune si l'événement est payant (null = gratuit).
  priceCents Int?
  // US-F05 — tarif réduit « cas social » (null = pas de tarif social).
  socialPriceCents Int?
  // US-F05 — si vrai, l'inscription reste provisoire tant qu'elle n'est pas payée.
  requirePayment Boolean @default(false)

  // US-L03/L06 — lieu de camp rattaché (pour un événement de type CAMP/WEEK_END).
  campPlaceId String?
  campPlace   CampPlace? @relation(fields: [campPlaceId], references: [id], onDelete: SetNull)

  registrations EventRegistration[]
  reminders     EventReminder[]
  attendances   Attendance[]
  loans         Loan[]
  expenses      Expense[]
  budgetLines   BudgetLine[]

  @@index([startDate])
  @@index([campPlaceId])
}

// US-L04 — lieu de camp : fiche partagée par le groupe (adresse géocodée,
// capacité, équipements, contact propriétaire, photos, avis).
model CampPlace {
  id            String   @id @default(cuid())
  name          String
  address       String?
  region        String? // pour le filtre régional (US-L01)
  latitude      Float? // coordonnées GPS auto-complétées (géocodage)
  longitude     Float?
  capacity      Int? // nombre de personnes
  equipmentJson String   @default("[]") // CampEquipment[] (JSON array)
  ownerName     String?
  ownerPhone    String?
  ownerEmail    String?
  notes         String? // notes pratiques
  photosJson    String   @default("[]") // string[] (URLs /uploads/…)
  createdById   String? // chef créateur (US-L05 : lui seul ou admin modifie)
  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  reviews CampPlaceReview[]
  events  Event[]

  @@index([archived])
}

// US-L06 — avis déposé sur un lieu après un camp (note 1–5 + commentaire).
// Plusieurs avis possibles par lieu (historique). La note moyenne est dérivée.
model CampPlaceReview {
  id        String   @id @default(cuid())
  placeId   String
  authorId  String? // chef auteur (null si compte supprimé)
  eventId   String? // camp à l'origine de l'avis (US-P01), facultatif
  rating    Int // 1..5
  comment   String?
  createdAt DateTime @default(now())

  place CampPlace @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
}

// US-F04 — ligne de budget prévisionnel d'un événement (un montant prévu par
// catégorie). Le « réel » est dérivé des notes de frais liées à l'événement.
model BudgetLine {
  id           String   @id @default(cuid())
  eventId      String
  category     String // ExpenseCategory
  plannedCents Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, category])
  @@index([eventId])
}

// US-F06/F07 — note de frais : une dépense avancée par un membre, à valider et
// rembourser par le trésorier. Montant stocké en centimes (entier, pas de float).
model Expense {
  id                  String    @id @default(cuid())
  declarantId         String
  amountCents         Int
  date                DateTime // date de la dépense (date « murale »)
  category            String // ExpenseCategory
  eventId             String? // dépense rattachée à un événement (optionnel)
  note                String?
  receiptUrl          String? // photo du reçu (obligatoire au-dessus de 20 €)
  status              String    @default("PENDING") // ExpenseStatus
  reviewedById        String?
  reviewedAt          DateTime?
  rejectionReason     String?
  reimbursedAt        DateTime?
  reimbursementMethod String? // espèces / chèque / virement
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @default(now()) @updatedAt

  declarant User   @relation("ExpenseDeclarant", fields: [declarantId], references: [id])
  reviewer  User?  @relation("ExpenseReviewer", fields: [reviewedById], references: [id])
  event     Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([declarantId])
}

// US-F01/F02 — campagne de cotisation. `amountCents` = montant attendu par jeune
// du périmètre (unité, ou groupe si null).
model Campaign {
  id          String    @id @default(cuid())
  name        String
  amountCents Int
  unit        String? // périmètre : null = tout le groupe
  deadline    DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  // US-F03 — cadence des relances (jours après l'échéance, JSON ex. [7,15,30])
  // et modèle de message (null = gabarit par défaut).
  reminderDaysJson String  @default("[7,15,30]")
  reminderTemplate String?
  // US-F01 — tarifs différenciés : `amountCents` = 1er enfant ; tarif 2e enfant
  // et tarif « cas social » optionnels ; nb de paiements échelonnés (1 = unique).
  secondChildCents Int?
  socialCents      Int?
  installments     Int     @default(1)

  payments    CampaignPayment[]
  reminders   CampaignReminder[]
  exemptions  CampaignExemption[]
  socialCases CampaignSocialCase[]

  @@index([unit])
}

// US-F01 — jeune au tarif « cas social » pour une campagne.
model CampaignSocialCase {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
}

// US-F10 — caisse (compte de trésorerie). Le solde est dérivé du grand livre.
model CashBox {
  id          String   @id @default(cuid())
  name        String
  archived    Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())

  transactions CashTransaction[]
}

// US-F10 — mouvement de caisse (montant signé : + entrée, − sortie). Un
// transfert entre caisses = deux mouvements partageant `transferGroupId`.
model CashTransaction {
  id              String   @id @default(cuid())
  cashBoxId       String
  amountCents     Int // signé : + entrée, − sortie
  label           String
  kind            String // DEPOSIT | WITHDRAWAL | TRANSFER
  date            DateTime
  transferGroupId String?
  createdById     String?
  createdAt       DateTime @default(now())

  cashBox CashBox @relation(fields: [cashBoxId], references: [id], onDelete: Cascade)

  @@index([cashBoxId])
}

// US-F03 — relance envoyée pour un jeune non à jour (dédup + historique).
model CampaignReminder {
  id         String   @id @default(cuid())
  campaignId String
  userId     String // le jeune relancé
  dayOffset  Int      @default(0) // étape de cadence (jours après l'échéance)
  sentAt     DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId, dayOffset])
  @@index([campaignId])
}

// US-F03 — « échelonnement convenu » : suspend les relances pour ce jeune.
model CampaignExemption {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
}

// Un paiement (total ou partiel) d'un jeune pour une campagne. Plusieurs
// paiements possibles par jeune (échelonnement).
model CampaignPayment {
  id           String   @id @default(cuid())
  campaignId   String
  userId       String // le jeune concerné
  amountCents  Int
  method       String // PaymentMethod
  paidAt       DateTime
  note         String?
  recordedById String?
  createdAt    DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation("CampaignPaymentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([userId])
}

// US-P07 — pointage de présence réelle à un événement (relevé par un chef),
// distinct de l'inscription/RSVP (intention du membre). Une ligne par
// (événement, membre) ; `present` modifiable. Alimente les stats US-P08/P09.
model Attendance {
  id         String   @id @default(cuid())
  eventId    String
  userId     String
  present    Boolean  @default(true)
  markedById String? // chef ayant pointé
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation("UserAttendance", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// US-P04 — réponse d'un membre à un événement (présent / absent / peut-être).
// Un enregistrement par (événement, utilisateur) ; la réponse est modifiable.
model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  response  String // RsvpResponse: PRESENT | ABSENT | MAYBE
  // US-F05 — montant déjà payé pour cette inscription (événement payant).
  paidCents Int      @default(0)
  // US-F05 — inscription au tarif « cas social » (tarif réduit de l'événement).
  social    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation("UserEventRegistration", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
}

// US-P10 — tâche (to-do) du planning : titre, responsable optionnel, échéance
// optionnelle, statut fait/à faire.
model Task {
  id          String    @id @default(cuid())
  title       String
  assigneeId  String?
  dueDate     DateTime? // échéance (date « murale », stockée en UTC)
  done        Boolean   @default(false)
  doneAt      DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  // US-P11 — tâche récurrente / ouverte au groupe.
  recurrence     String    @default("NONE") // NONE | DAILY | WEEKLY | MONTHLY | YEARLY
  recurrenceEvery Int      @default(1) // intervalle (ex. toutes les 2 semaines)
  groupTask      Boolean   @default(false) // ouverte à l'inscription du groupe
  minRequired    Int       @default(0) // nb minimum d'inscrits pour être couverte
  nextGenerated  Boolean   @default(false) // l'occurrence suivante a été générée
  reminderSentAt DateTime? // dédup de la relance/rappel d'échéance

  assignee User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  signups  TaskSignup[]

  @@index([done])
  @@index([dueDate])
}

// US-P11 — inscription d'un membre sur une tâche ouverte au groupe.
model TaskSignup {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskSignupUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
}

// Rattachement familial : un lien parent → jeune. Permet à un parent d'agir
// pour son enfant (ex. inscription à un événement, US-P04). Géré par
// l'administration (user.manage).
model FamilyLink {
  id        String   @id @default(cuid())
  parentId  String
  childId   String
  createdAt DateTime @default(now())

  parent User @relation("FamilyParent", fields: [parentId], references: [id], onDelete: Cascade)
  child  User @relation("FamilyChild", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
}

// US-P06 — relance automatique envoyée à un membre non-répondant avant la date
// limite d'inscription. Une ligne par (événement, utilisateur) : sert à la fois
// de garde anti-doublon et de trace visible par le chef (« qui a été relancé »).
model EventReminder {
  id      String   @id @default(cuid())
  eventId String
  userId  String
  sentAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation("UserEventReminder", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
}

// ----------------------------------------------------------------------------
// Communication (US-C09) — salons/canaux type Discord, messages, réactions.
// ----------------------------------------------------------------------------

model ChannelCategory {
  id        String    @id @default(cuid())
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  channels  Channel[]
}

model Channel {
  id          String   @id @default(cuid())
  categoryId  String?
  name        String
  slug        String   @unique
  description String?
  order       Int      @default(0)
  archived    Boolean  @default(false)
  // Accès : si accessRoles ET accessUnits sont vides → ouvert à tous les ACTIVE.
  // Sinon, autorisé si le rôle ∈ accessRoles OU l'unité ∈ accessUnits.
  // excludeUnits permet le motif « tous sauf X ». ADMIN voit tout.
  accessRoles  String  @default("[]") // JSON Role[]
  accessUnits  String  @default("[]") // JSON Unit[]
  excludeUnits String  @default("[]") // JSON Unit[]
  createdAt   DateTime @default(now())

  category  ChannelCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages  Message[]
  reads     ChannelRead[]
  mutes     ChannelMute[]
  polls     Poll[]

  @@index([categoryId])
  @@index([archived])
}

// US-C09 — salon coupé (mute) pour un utilisateur : plus de notification de
// nouveaux messages pour ce salon (il reste visible et lisible).
model ChannelMute {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation("ChannelMuteUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model Message {
  id          String    @id @default(cuid())
  channelId   String
  authorId    String
  body        String
  attachments String    @default("[]") // JSON string[] (chemins /uploads)
  editedAt    DateTime?
  pinnedAt    DateTime?
  createdAt   DateTime  @default(now())

  channel   Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User              @relation("MessageAuthor", fields: [authorId], references: [id])
  reactions MessageReaction[]

  @@index([channelId])
  @@index([createdAt])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("ReactionUser", fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ChannelRead {
  id         String   @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation("ChannelReadUser", fields: [userId], references: [id])

  @@unique([channelId, userId])
  @@index([userId])
}

// US-C06 — sondage dans un salon (choix multiple / oui-non / disponibilités).
model Poll {
  id            String    @id @default(cuid())
  channelId     String
  authorId      String
  question      String
  options       String // JSON: { id: string; label: string }[]
  allowMultiple Boolean   @default(false)
  closesAt      DateTime?
  closedAt      DateTime?
  // US-16 — sondage généré depuis un prêt (groupId) pour traçabilité.
  loanGroupId   String?
  createdAt     DateTime  @default(now())

  channel Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author  User       @relation("PollAuthor", fields: [authorId], references: [id])
  votes   PollVote[]

  @@index([channelId])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  userId    String
  optionId  String
  createdAt DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation("PollVoteUser", fields: [userId], references: [id])

  @@unique([pollId, userId, optionId])
  @@index([pollId])
}

// ----------------------------------------------------------------------------
// Notifications (modèle transverse) — alimentent la cloche in-app temps réel,
// + canaux email (Resend) et push web (VAPID). Une notification appartient à un
// destinataire (User). `count` permet la coalescence (ex. « 3 nouveaux messages
// dans #général » au lieu de 3 lignes). Non audité (artefact système dérivé,
// comme ChannelRead / MessageReaction).
// ----------------------------------------------------------------------------

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // NotificationType (cf. src/lib/enums.ts)
  title     String
  body      String
  link      String? // route in-app à ouvrir au clic
  channelId String? // contexte salon (coalescence des messages)
  messageId String?
  count     Int       @default(1) // nb d'occurrences coalescées
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation("UserNotification", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// Abonnement Web Push (un par navigateur/appareil). Supprimé si l'endpoint
// renvoie 404/410 à l'envoi.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Préférences de notification par utilisateur. L'in-app est toujours actif ;
// email et push sont désactivables. Le mute par salon vit dans ChannelMute.
model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  emailEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// US-C01 / US-C05 — annonce du groupe (titre, texte, pièces jointes) ciblée par
// audience, avec notification push + email. `urgent` (US-C05) force la diffusion
// en contournant les préférences de notification du destinataire.
model Announcement {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  body        String
  attachments String   @default("[]") // JSON string[] (chemins /uploads)
  audience    String   @default("ALL") // ALL | PARENTS | <Unit> (cf. enums.ts)
  urgent      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User              @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  reads  AnnouncementRead[]

  @@index([createdAt])
}

// US-C03 — suivi de lecture d'une annonce (qui l'a lue, quand). Une ligne par
// (annonce, lecteur) ; alimente le taux de lecture et la relance des non-lecteurs.
model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation("AnnouncementReadUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([announcementId])
}

// US-C04 — messagerie directe 1-to-1. Une conversation par paire d'utilisateurs ;
// les ids sont rangés de façon canonique (userAId < userBId) pour garantir
// l'unicité quel que soit l'ordre d'ouverture.
model Conversation {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // remontée à chaque message (tri de la liste)

  userA    User            @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User            @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([updatedAt])
}

// US-C04 — message direct. `readAt` = accusé de lecture (lu par le destinataire,
// l'unique autre participant de la conversation 1-to-1).
model DirectMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("DirectMessageSender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}
